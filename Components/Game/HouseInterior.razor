@page "/house"
@rendermode InteractiveServer
@inject BlazorStarter.Services.GameState GameState
@implements IDisposable

<PageTitle>Devil's Gorge - Inside the House</PageTitle>

<div class="house-interior-container">
    <svg viewBox="0 0 800 600" class="house-scene" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <!-- Wall wood gradient -->
            <linearGradient id="wallGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#2a1f14"/>
                <stop offset="50%" stop-color="#3d2b1f"/>
                <stop offset="100%" stop-color="#1a1208"/>
            </linearGradient>

            <!-- Floor gradient with perspective feel -->
            <linearGradient id="floorGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#2a1f14"/>
                <stop offset="100%" stop-color="#0d0906"/>
            </linearGradient>

            <!-- Fireplace glow -->
            <radialGradient id="fireGlow" cx="50%" cy="80%" r="60%">
                <stop offset="0%" stop-color="#ff6b1a" stop-opacity="0.8"/>
                <stop offset="40%" stop-color="#ff4500" stop-opacity="0.4"/>
                <stop offset="100%" stop-color="#ff4500" stop-opacity="0"/>
            </radialGradient>

            <!-- Ember glow -->
            <radialGradient id="emberGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#ffaa00"/>
                <stop offset="60%" stop-color="#ff6600"/>
                <stop offset="100%" stop-color="#cc3300"/>
            </radialGradient>

            <!-- Ambient light from fire -->
            <radialGradient id="ambientFireLight" cx="18%" cy="75%" r="45%">
                <stop offset="0%" stop-color="#ff6b1a" stop-opacity="0.15"/>
                <stop offset="100%" stop-color="#ff6b1a" stop-opacity="0"/>
            </radialGradient>

            <!-- Window night sky -->
            <linearGradient id="nightSky" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#0a0a15"/>
                <stop offset="100%" stop-color="#1a1a2e"/>
            </linearGradient>

            <!-- Moonlight glow -->
            <radialGradient id="moonGlow" cx="50%" cy="30%" r="40%">
                <stop offset="0%" stop-color="#e8e8ff" stop-opacity="0.3"/>
                <stop offset="100%" stop-color="#e8e8ff" stop-opacity="0"/>
            </radialGradient>

            <!-- Stone texture for fireplace -->
            <pattern id="stonePattern" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
                <rect width="20" height="20" fill="#3a3a3a"/>
                <rect x="0" y="0" width="9" height="9" fill="#4a4a4a"/>
                <rect x="10" y="10" width="9" height="9" fill="#4a4a4a"/>
                <rect x="0" y="10" width="9" height="9" fill="#3d3d3d"/>
                <rect x="10" y="0" width="9" height="9" fill="#3d3d3d"/>
            </pattern>

            <!-- Lantern glass glow -->
            <radialGradient id="lanternGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#ffdd66" stop-opacity="0.9"/>
                <stop offset="50%" stop-color="#ffaa22" stop-opacity="0.5"/>
                <stop offset="100%" stop-color="#ff8800" stop-opacity="0"/>
            </radialGradient>

            <!-- Lantern ambient -->
            <radialGradient id="lanternAmbient" cx="50%" cy="50%" r="70%">
                <stop offset="0%" stop-color="#ffcc44" stop-opacity="0.2"/>
                <stop offset="100%" stop-color="#ffcc44" stop-opacity="0"/>
            </radialGradient>

            <!-- Steel metallic -->
            <linearGradient id="steelGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#8a9197"/>
                <stop offset="50%" stop-color="#6b7178"/>
                <stop offset="100%" stop-color="#4a5258"/>
            </linearGradient>

            <!-- Flint stone -->
            <linearGradient id="flintGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#4a4a4a"/>
                <stop offset="50%" stop-color="#2d2d2d"/>
                <stop offset="100%" stop-color="#1a1a1a"/>
            </linearGradient>

            <!-- Wood plank pattern -->
            <pattern id="woodGrain" x="0" y="0" width="100" height="30" patternUnits="userSpaceOnUse">
                <rect width="100" height="30" fill="#3d2b1f"/>
                <line x1="0" y1="5" x2="100" y2="5" stroke="#2a1f14" stroke-width="0.5" opacity="0.5"/>
                <line x1="0" y1="15" x2="100" y2="14" stroke="#4a3728" stroke-width="0.3" opacity="0.3"/>
                <line x1="0" y1="25" x2="100" y2="26" stroke="#2a1f14" stroke-width="0.5" opacity="0.4"/>
                <ellipse cx="30" cy="15" rx="3" ry="2" fill="#2a1f14" opacity="0.4"/>
                <ellipse cx="75" cy="8" rx="2" ry="1.5" fill="#2a1f14" opacity="0.3"/>
            </pattern>

            <!-- Backpack leather -->
            <linearGradient id="leatherGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#5a4030"/>
                <stop offset="50%" stop-color="#4a3020"/>
                <stop offset="100%" stop-color="#3a2010"/>
            </linearGradient>

            <!-- Inventory slot -->
            <linearGradient id="slotGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#2a1a10"/>
                <stop offset="100%" stop-color="#1a0a00"/>
            </linearGradient>

            <!-- Shadow filter -->
            <filter id="shadow" x="-50%" y="-50%" width="200%" height="200%">
                <feDropShadow dx="2" dy="4" stdDeviation="3" flood-color="#000" flood-opacity="0.5"/>
            </filter>

            <!-- Glow filter for selected items -->
            <filter id="itemGlow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feFlood flood-color="#ffcc66" flood-opacity="0.6"/>
                <feComposite in2="blur" operator="in"/>
                <feMerge>
                    <feMergeNode/>
                    <feMergeNode in="SourceGraphic"/>
                </feMerge>
            </filter>
        </defs>

        <!-- Background / Back wall -->
        <rect x="0" y="0" width="800" height="600" fill="#1a1208"/>

        <!-- Back wall with wood planks -->
        <g class="back-wall">
            @for (int i = 0; i < 14; i++)
            {
                <rect x="0" y="@(i * 30)" width="800" height="30" fill="url(#woodGrain)" opacity="0.9"/>
                <line x1="0" y1="@(i * 30)" x2="800" y2="@(i * 30)" stroke="#0d0906" stroke-width="2"/>
            }
        </g>

        <!-- Ambient fire light on walls -->
        <rect x="0" y="0" width="800" height="600" fill="url(#ambientFireLight)"/>

        <!-- Floor -->
        <g class="floor">
            <polygon points="0,420 800,420 800,600 0,600" fill="url(#floorGradient)"/>
            <!-- Floor boards -->
            @for (int i = 0; i < 10; i++)
            {
                <line x1="@(i * 90 - 50)" y1="420" x2="@(i * 100 - 100)" y2="600" stroke="#0d0906" stroke-width="3"/>
            }
            <!-- Floor board grain lines -->
            <line x1="0" y1="460" x2="800" y2="460" stroke="#3d2b1f" stroke-width="1" opacity="0.3"/>
            <line x1="0" y1="510" x2="800" y2="510" stroke="#3d2b1f" stroke-width="1" opacity="0.2"/>
            <line x1="0" y1="560" x2="800" y2="560" stroke="#3d2b1f" stroke-width="1" opacity="0.15"/>
        </g>

        <!-- Stone Fireplace -->
        <g class="fireplace">
            <!-- Fireplace structure -->
            <rect x="30" y="200" width="180" height="220" fill="url(#stonePattern)" rx="5"/>
            <!-- Fireplace opening -->
            <path d="M50 420 L50 300 Q50 270 80 270 L160 270 Q190 270 190 300 L190 420 Z" fill="#0a0505"/>
            <!-- Mantle -->
            <rect x="20" y="190" width="200" height="20" fill="#2d2d2d" rx="3"/>
            <rect x="25" y="185" width="190" height="10" fill="#3d3d3d" rx="2"/>

            <!-- Fire glow background -->
            <ellipse cx="120" cy="400" rx="60" ry="40" fill="url(#fireGlow)" class="fire-glow"/>

            <!-- Burning logs -->
            <g class="logs">
                <ellipse cx="90" cy="400" rx="35" ry="8" fill="#1a0a00" transform="rotate(-15, 90, 400)"/>
                <ellipse cx="150" cy="405" rx="30" ry="7" fill="#1a0a00" transform="rotate(10, 150, 405)"/>
                <ellipse cx="120" cy="395" rx="25" ry="6" fill="#2a0a00" transform="rotate(-5, 120, 395)"/>
            </g>

            <!-- Embers -->
            <g class="embers">
                <circle cx="100" cy="390" r="3" fill="url(#emberGlow)" class="ember ember-1"/>
                <circle cx="130" cy="385" r="4" fill="url(#emberGlow)" class="ember ember-2"/>
                <circle cx="145" cy="392" r="2.5" fill="url(#emberGlow)" class="ember ember-3"/>
                <circle cx="110" cy="380" r="2" fill="url(#emberGlow)" class="ember ember-4"/>
                <circle cx="135" cy="395" r="3" fill="url(#emberGlow)" class="ember ember-5"/>
            </g>

            <!-- Flames -->
            <g class="flames">
                <path d="M110 390 Q105 360 115 340 Q120 360 115 370 Q125 350 120 330 Q130 355 125 380 Q120 385 110 390"
                      fill="#ff6600" class="flame flame-1" opacity="0.9"/>
                <path d="M125 395 Q118 370 128 355 Q133 375 130 385 Q138 365 135 345 Q145 365 140 390 Q135 393 125 395"
                      fill="#ff8800" class="flame flame-2" opacity="0.85"/>
                <path d="M140 392 Q137 375 143 360 Q147 378 145 385 Q150 370 148 355 Q155 372 150 388 Q147 391 140 392"
                      fill="#ffaa00" class="flame flame-3" opacity="0.8"/>
                <!-- Inner bright flames -->
                <path d="M118 388 Q115 375 120 365 Q123 377 121 382 Q126 372 124 362 Q130 374 126 385 Q123 387 118 388"
                      fill="#ffcc44" class="flame flame-inner-1" opacity="0.9"/>
                <path d="M132 390 Q130 380 134 372 Q136 382 135 386 Q138 378 137 370 Q142 380 139 388 Q136 389 132 390"
                      fill="#ffdd66" class="flame flame-inner-2" opacity="0.85"/>
            </g>
        </g>

        <!-- Window on right wall -->
        <g class="window">
            <!-- Window frame outer -->
            <rect x="580" y="120" width="140" height="180" fill="#2d2d2d" rx="3"/>
            <!-- Window inner frame -->
            <rect x="590" y="130" width="120" height="160" fill="url(#nightSky)" rx="2"/>
            <!-- Moon glow -->
            <circle cx="650" cy="170" r="40" fill="url(#moonGlow)"/>
            <!-- Moon -->
            <circle cx="660" cy="165" r="12" fill="#e8e8f0" opacity="0.9"/>
            <!-- Stars -->
            <circle cx="610" cy="150" r="1" fill="#fff" opacity="0.8"/>
            <circle cx="630" cy="180" r="0.8" fill="#fff" opacity="0.6"/>
            <circle cx="690" cy="145" r="1.2" fill="#fff" opacity="0.7"/>
            <circle cx="680" cy="200" r="0.8" fill="#fff" opacity="0.5"/>
            <circle cx="620" cy="220" r="1" fill="#fff" opacity="0.6"/>
            <circle cx="700" cy="175" r="0.6" fill="#fff" opacity="0.5"/>
            <!-- Window frame dividers -->
            <line x1="650" y1="130" x2="650" y2="290" stroke="#2d2d2d" stroke-width="6"/>
            <line x1="590" y1="210" x2="710" y2="210" stroke="#2d2d2d" stroke-width="6"/>
            <!-- Window sill -->
            <rect x="575" y="290" width="150" height="15" fill="#3d3d3d" rx="2"/>
        </g>

        <!-- Wooden table/shelf for items -->
        <g class="item-table" filter="url(#shadow)">
            <!-- Table top -->
            <rect x="320" y="340" width="200" height="12" fill="#4a3728" rx="2"/>
            <rect x="325" y="338" width="190" height="6" fill="#5a4738"/>
            <!-- Table legs -->
            <rect x="335" y="352" width="15" height="68" fill="#3d2b1f"/>
            <rect x="490" y="352" width="15" height="68" fill="#3d2b1f"/>
            <!-- Cross beam -->
            <rect x="345" y="380" width="150" height="8" fill="#3d2b1f"/>
            <!-- Wood grain details on table -->
            <line x1="330" y1="341" x2="510" y2="341" stroke="#3d2b1f" stroke-width="1" opacity="0.5"/>
        </g>

        <!-- Flint & Steel Item -->
        @{
            var flintCollected = GameState.IsItemCollected(FlintSteelId);
            var lanternCollected = GameState.IsItemCollected(LanternId);
            var anyItemCollected = flintCollected || lanternCollected;
            var flintDisabled = !flintCollected && lanternCollected;
            var lanternDisabled = !lanternCollected && flintCollected;
        }
        @if (!flintCollected)
        {
            <g class="item flint-steel @(IsFlintHovered() ? "hovered" : "") @(collectingItem == FlintSteelId ? "collecting" : "") @(flintDisabled ? "disabled" : "")"
               @onclick="OnFlintSteelClickAsync"
               @onmouseenter="OnFlintSteelEnter"
               @onmouseleave="OnMouseLeave"
               style="pointer-events: all; cursor: @(flintDisabled ? "not-allowed" : "pointer");"
               filter="@(IsFlintHovered() && !flintDisabled ? "url(#itemGlow)" : "")"
               opacity="@(flintDisabled ? "0.4" : "1")">
                <!-- Invisible hit area for better click detection -->
                <rect x="345" y="285" width="85" height="65" fill="transparent"/>
                <!-- Flint stone -->
                <path d="M350 338 L358 310 L378 305 L392 318 L388 340 L365 342 Z"
                      fill="url(#flintGradient)" stroke="#1a1a1a" stroke-width="1"/>
                <!-- Flint highlights -->
                <path d="M360 315 L370 312 L378 320 L372 328 L362 325 Z" fill="#4a4a4a" opacity="0.6"/>
                <!-- Sharp edge shine -->
                <line x1="378" y1="305" x2="392" y2="318" stroke="#6a6a6a" stroke-width="1.5"/>

                <!-- Steel striker -->
                <path d="M385 295 Q400 288 415 295 L422 308 Q426 318 420 328 L410 332 Q398 336 388 328 L382 315 Q378 305 385 295"
                      fill="url(#steelGradient)" stroke="#2a2a2a" stroke-width="1"/>
                <!-- Steel curve highlight -->
                <path d="M390 298 Q402 293 412 300" stroke="#a0a8ad" stroke-width="1.5" fill="none"/>
                <!-- Finger grip hole -->
                <ellipse cx="402" cy="312" rx="6" ry="10" fill="#2a2a2a" stroke="#4a4a4a" stroke-width="1"/>
                <!-- Inner hole highlight -->
                <ellipse cx="402" cy="312" rx="4" ry="7" fill="none" stroke="#1a1a1a" stroke-width="0.5"/>
            </g>
        }

        <!-- Lantern Item -->
        @if (!lanternCollected)
        {
            <g class="item lantern @(IsLanternHovered() ? "hovered" : "") @(collectingItem == LanternId ? "collecting" : "") @(lanternDisabled ? "disabled" : "")"
               @onclick="OnLanternClickAsync"
               @onmouseenter="OnLanternEnter"
               @onmouseleave="OnMouseLeave"
               style="pointer-events: all; cursor: @(lanternDisabled ? "not-allowed" : "pointer");"
               filter="@(IsLanternHovered() && !lanternDisabled ? "url(#itemGlow)" : "")"
               opacity="@(lanternDisabled ? "0.4" : "1")">
                <!-- Invisible hit area for better click detection -->
                <rect x="448" y="245" width="65" height="120" fill="transparent"/>

                <!-- Lantern ambient glow -->
                <ellipse cx="480" cy="300" rx="50" ry="50" fill="url(#lanternAmbient)" class="lantern-ambient-glow" opacity="@(lanternDisabled ? "0.3" : "1")"/>

                <!-- Handle -->
                <path d="M465 260 Q480 248 495 260" fill="none" stroke="#4a3a2a" stroke-width="4" stroke-linecap="round"/>
                <circle cx="465" cy="260" r="3" fill="#3a2a1a"/>
                <circle cx="495" cy="260" r="3" fill="#3a2a1a"/>

                <!-- Top cap -->
                <path d="M458 268 L502 268 L498 258 L462 258 Z" fill="#5a4a3a" stroke="#3a2a1a" stroke-width="1"/>
                <!-- Chimney -->
                <rect x="473" y="250" width="14" height="10" rx="2" fill="#2a2a2a" stroke="#1a1a1a" stroke-width="0.5"/>

                <!-- Main glass body -->
                <path d="M458 268 L453 338 Q453 348 463 348 L497 348 Q507 348 507 338 L502 268"
                      fill="#1a1a1a" fill-opacity="0.3" stroke="#4a4a4a" stroke-width="1.5"/>

                <!-- Glass panels (vertical lines) -->
                <line x1="463" y1="272" x2="458" y2="345" stroke="#3a3a3a" stroke-width="1"/>
                <line x1="480" y1="268" x2="480" y2="348" stroke="#3a3a3a" stroke-width="1"/>
                <line x1="497" y1="272" x2="502" y2="345" stroke="#3a3a3a" stroke-width="1"/>

                <!-- Inner glow -->
                <ellipse cx="480" cy="310" rx="18" ry="28" fill="url(#lanternGlow)" class="lantern-inner-glow" opacity="@(lanternDisabled ? "0.3" : "1")"/>

                <!-- Wick holder -->
                <rect x="475" y="325" width="10" height="15" fill="#3a3a3a"/>

                <!-- Flame -->
                @if (!lanternDisabled)
                {
                    <g class="lantern-flame">
                        <path d="M480 322 Q475 308 480 295 Q485 308 480 322" fill="#ff9933" class="lantern-flame-outer"/>
                        <path d="M480 320 Q477 310 480 300 Q483 310 480 320" fill="#ffcc66"/>
                        <path d="M480 318 Q478 312 480 305 Q482 312 480 318" fill="#ffeeaa"/>
                    </g>
                }

                <!-- Bottom base -->
                <rect x="450" y="348" width="60" height="10" rx="2" fill="#5a4a3a" stroke="#3a2a1a" stroke-width="1"/>
                <rect x="453" y="353" width="54" height="5" fill="#4a3a2a"/>

                <!-- Metal frame bands -->
                <line x1="453" y1="290" x2="507" y2="290" stroke="#4a4a4a" stroke-width="2"/>
                <line x1="453" y1="330" x2="507" y2="330" stroke="#4a4a4a" stroke-width="2"/>
            </g>
        }

        <!-- Dust particles overlay -->
        <g class="dust-particles" opacity="0.3">
            <circle cx="200" cy="150" r="1" fill="#c9b896" class="dust dust-1"/>
            <circle cx="450" cy="200" r="0.8" fill="#c9b896" class="dust dust-2"/>
            <circle cx="350" cy="100" r="1.2" fill="#c9b896" class="dust dust-3"/>
            <circle cx="600" cy="300" r="0.7" fill="#c9b896" class="dust dust-4"/>
            <circle cx="150" cy="350" r="1" fill="#c9b896" class="dust dust-5"/>
            <circle cx="500" cy="150" r="0.9" fill="#c9b896" class="dust dust-6"/>
            <circle cx="280" cy="250" r="0.8" fill="#c9b896" class="dust dust-7"/>
            <circle cx="700" cy="400" r="1.1" fill="#c9b896" class="dust dust-8"/>
        </g>

        <!-- Cobwebs -->
        <g class="cobwebs" opacity="0.15">
            <!-- Top left cobweb -->
            <path d="M0 0 Q30 30 0 60" stroke="#ccc" stroke-width="0.5" fill="none"/>
            <path d="M0 0 Q40 20 80 0" stroke="#ccc" stroke-width="0.5" fill="none"/>
            <path d="M0 0 L50 50" stroke="#ccc" stroke-width="0.3" fill="none"/>
            <path d="M0 30 Q25 35 50 25" stroke="#ccc" stroke-width="0.3" fill="none"/>
            <!-- Top right cobweb -->
            <path d="M800 0 Q770 30 800 60" stroke="#ccc" stroke-width="0.5" fill="none"/>
            <path d="M800 0 Q760 20 720 0" stroke="#ccc" stroke-width="0.5" fill="none"/>
            <path d="M800 0 L750 50" stroke="#ccc" stroke-width="0.3" fill="none"/>
        </g>

        <!-- Vignette overlay -->
        <rect x="0" y="0" width="800" height="600" fill="url(#ambientFireLight)" opacity="0.5"/>
    </svg>
</div>

<!-- SVG Inventory Backpack - Outside container for proper fixed positioning -->
<div class="inventory-backpack @(showInventory ? "open" : "")">
    <svg viewBox="0 0 120 140" class="backpack-svg" @onclick="ToggleInventory" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="bpLeather" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="#6a5040"/>
                    <stop offset="50%" stop-color="#5a4030"/>
                    <stop offset="100%" stop-color="#4a3020"/>
                </linearGradient>
                <linearGradient id="bpDarkLeather" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="#4a3525"/>
                    <stop offset="100%" stop-color="#3a2515"/>
                </linearGradient>
            </defs>

            <!-- Backpack straps -->
            <path d="M30 25 L30 10 Q30 5 35 5 L42 5" fill="none" stroke="#5a4535" stroke-width="5" stroke-linecap="round"/>
            <path d="M90 25 L90 10 Q90 5 85 5 L78 5" fill="none" stroke="#5a4535" stroke-width="5" stroke-linecap="round"/>

            <!-- Main backpack body -->
            <path d="M20 35 L20 120 Q20 130 35 130 L85 130 Q100 130 100 120 L100 35 Q100 25 85 25 L35 25 Q20 25 20 35"
                  fill="url(#bpLeather)" stroke="#3a2515" stroke-width="2"/>

            <!-- Top flap -->
            <path d="M25 35 Q25 20 60 18 Q95 20 95 35" fill="url(#bpLeather)" stroke="#3a2515" stroke-width="1.5"/>
            <path d="M30 32 Q30 22 60 20 Q90 22 90 32" fill="none" stroke="#6a5545" stroke-width="1"/>

            <!-- Front pocket -->
            <rect x="35" y="70" width="50" height="35" rx="3" fill="url(#bpDarkLeather)" stroke="#3a2515" stroke-width="1"/>

            <!-- Pocket flap -->
            <path d="M35 70 L35 60 Q35 55 45 55 L75 55 Q85 55 85 60 L85 70" fill="url(#bpLeather)" stroke="#3a2515" stroke-width="1"/>

            <!-- Buckle -->
            <rect x="52" y="62" width="16" height="10" rx="1" fill="#8b7355" stroke="#5a4535" stroke-width="1"/>
            <rect x="55" y="65" width="10" height="4" rx="0.5" fill="#3a2515"/>

            <!-- Stitching details -->
            <path d="M25 40 L25 115" stroke="#3a2515" stroke-width="1" stroke-dasharray="3,2"/>
            <path d="M95 40 L95 115" stroke="#3a2515" stroke-width="1" stroke-dasharray="3,2"/>

            <!-- Item count badge -->
            @if (GameState.Inventory.Count > 0)
            {
                <circle cx="95" cy="30" r="12" fill="#8b4513" stroke="#5a3010" stroke-width="2"/>
                <!-- Badge number using circles as dots for count -->
                @if (GameState.Inventory.Count == 1)
                {
                    <circle cx="95" cy="30" r="3" fill="#f4e4c1"/>
                }
                else if (GameState.Inventory.Count == 2)
                {
                    <circle cx="91" cy="30" r="2.5" fill="#f4e4c1"/>
                    <circle cx="99" cy="30" r="2.5" fill="#f4e4c1"/>
                }
            }
        </svg>

        <!-- Inventory panel -->
        @if (showInventory)
        {
            <div class="inventory-panel">
                <svg viewBox="0 0 200 200" class="inventory-panel-svg" xmlns="http://www.w3.org/2000/svg">
                    <!-- Panel background -->
                    <rect x="5" y="5" width="190" height="190" rx="8" fill="#2a1f14" stroke="#5a4a3a" stroke-width="3"/>

                    <!-- Header bar -->
                    <rect x="10" y="10" width="180" height="30" rx="5" fill="#3d2b1f"/>
                    <!-- Header decoration -->
                    <circle cx="30" cy="25" r="5" fill="#5a4a3a"/>
                    <circle cx="170" cy="25" r="5" fill="#5a4a3a"/>
                    <line x1="45" y1="25" x2="155" y2="25" stroke="#5a4a3a" stroke-width="2"/>

                    <!-- Item slots -->
                    <g class="inventory-slots">
                        <!-- Slot 1 -->
                        <rect x="20" y="50" width="70" height="70" rx="5" fill="url(#slotGradient)" stroke="#4a3a2a" stroke-width="2"/>
                        @if (GameState.HasItem(FlintSteelId))
                        {
                            <!-- Flint & Steel in inventory -->
                            <g transform="translate(25, 50) scale(0.55)">
                                <path d="M20 55 L28 25 L50 20 L65 35 L60 58 L35 60 Z" fill="url(#flintGradient)" stroke="#1a1a1a" stroke-width="1"/>
                                <path d="M30 30 L42 27 L52 37 L45 47 L33 43 Z" fill="#4a4a4a" opacity="0.6"/>
                                <path d="M58 10 Q75 2 92 10 L100 25 Q105 37 98 48 L86 53 Q72 58 60 48 L53 32 Q48 20 58 10"
                                      fill="url(#steelGradient)" stroke="#2a2a2a" stroke-width="1"/>
                                <ellipse cx="77" cy="30" rx="6" ry="10" fill="#2a2a2a"/>
                            </g>
                        }
                        else
                        {
                            <!-- Empty slot indicator -->
                            <circle cx="55" cy="85" r="8" fill="none" stroke="#3a3a3a" stroke-width="1" stroke-dasharray="2,2"/>
                        }

                        <!-- Slot 2 -->
                        <rect x="110" y="50" width="70" height="70" rx="5" fill="url(#slotGradient)" stroke="#4a3a2a" stroke-width="2"/>
                        @if (GameState.HasItem(LanternId))
                        {
                            <!-- Lantern in inventory -->
                            <g transform="translate(115, 48) scale(0.5)">
                                <path d="M30 22 Q50 10 70 22" fill="none" stroke="#4a3a2a" stroke-width="4"/>
                                <path d="M22 35 L78 35 L73 27 L27 27 Z" fill="#5a4a3a" stroke="#3a2a1a" stroke-width="1"/>
                                <path d="M22 35 L15 105 Q15 118 28 118 L72 118 Q85 118 85 105 L78 35"
                                      fill="#1a1a1a" fill-opacity="0.3" stroke="#4a4a4a" stroke-width="1.5"/>
                                <ellipse cx="50" cy="75" rx="18" ry="28" fill="url(#lanternGlow)" opacity="0.8"/>
                                <path d="M50 88 Q44 72 50 55 Q56 72 50 88" fill="#ffcc66"/>
                                <rect x="12" y="118" width="76" height="12" rx="2" fill="#5a4a3a"/>
                            </g>
                        }
                        else
                        {
                            <!-- Empty slot indicator -->
                            <circle cx="145" cy="85" r="8" fill="none" stroke="#3a3a3a" stroke-width="1" stroke-dasharray="2,2"/>
                        }
                    </g>

                    <!-- Decorative corners -->
                    <path d="M12 12 L25 12 L25 16 L16 16 L16 25 L12 25 Z" fill="#5a4a3a"/>
                    <path d="M188 12 L175 12 L175 16 L184 16 L184 25 L188 25 Z" fill="#5a4a3a"/>
                    <path d="M12 188 L25 188 L25 184 L16 184 L16 175 L12 175 Z" fill="#5a4a3a"/>
                    <path d="M188 188 L175 188 L175 184 L184 184 L184 175 L188 175 Z" fill="#5a4a3a"/>

                    <!-- Bottom decoration -->
                    <rect x="60" y="145" width="80" height="8" rx="2" fill="#3d2b1f"/>
                    <rect x="75" y="160" width="50" height="6" rx="2" fill="#3d2b1f"/>
                </svg>
            </div>
        }
</div>

<!-- Collection animation overlay -->
@if (!string.IsNullOrEmpty(collectingItem))
{
    <div class="collection-animation @collectingItem">
        <svg viewBox="0 0 100 100" class="collecting-item-svg" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="collectFlint" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#4a4a4a"/>
                    <stop offset="100%" stop-color="#1a1a1a"/>
                </linearGradient>
                <linearGradient id="collectSteel" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#8a9197"/>
                    <stop offset="100%" stop-color="#4a5258"/>
                </linearGradient>
                <radialGradient id="collectLanternGlow" cx="50%" cy="50%" r="50%">
                    <stop offset="0%" stop-color="#ffdd66" stop-opacity="0.9"/>
                    <stop offset="100%" stop-color="#ff8800" stop-opacity="0"/>
                </radialGradient>
            </defs>
            @if (collectingItem == FlintSteelId)
            {
                <g transform="translate(10, 15) scale(0.8)">
                    <path d="M20 50 L28 22 L48 17 L62 30 L58 52 L35 54 Z" fill="url(#collectFlint)" stroke="#1a1a1a" stroke-width="1"/>
                    <path d="M55 7 Q70 0 85 7 L92 20 Q96 30 90 40 L80 44 Q68 48 58 40 L52 27 Q48 17 55 7"
                          fill="url(#collectSteel)" stroke="#2a2a2a" stroke-width="1"/>
                    <ellipse cx="72" cy="24" rx="5" ry="8" fill="#2a2a2a"/>
                </g>
            }
            else if (collectingItem == LanternId)
            {
                <g transform="translate(20, 5) scale(0.7)">
                    <path d="M25 25 Q40 15 55 25" fill="none" stroke="#4a3a2a" stroke-width="3"/>
                    <path d="M18 35 L62 35 L58 28 L22 28 Z" fill="#5a4a3a"/>
                    <path d="M18 35 L13 95 Q13 105 23 105 L57 105 Q67 105 67 95 L62 35"
                          fill="#1a1a1a" fill-opacity="0.3" stroke="#4a4a4a" stroke-width="1"/>
                    <ellipse cx="40" cy="70" rx="15" ry="22" fill="url(#collectLanternGlow)" opacity="0.8"/>
                    <path d="M40 80 Q36 68 40 55 Q44 68 40 80" fill="#ffcc66"/>
                    <rect x="10" y="105" width="60" height="10" rx="2" fill="#5a4a3a"/>
                </g>
            }
        </svg>
    </div>
}

@code {
    private const string FlintSteelId = "flint-steel";
    private const string LanternId = "lantern";

    private string? hoveredItem;
    private string? collectingItem;
    private bool showInventory;

    private static readonly GameItem FlintSteel = new()
    {
        Id = FlintSteelId,
        Name = "Flint & Steel",
        Description = "A worn flint stone and steel striker. Could start a fire.",
        IconType = "flint-steel"
    };

    private static readonly GameItem Lantern = new()
    {
        Id = LanternId,
        Name = "Old Lantern",
        Description = "An antique oil lantern. The glass is dusty but intact.",
        IconType = "lantern"
    };

    protected override void OnInitialized()
    {
        GameState.OnStateChanged += StateHasChanged;
    }

    private void ToggleInventory()
    {
        showInventory = !showInventory;
    }

    private bool IsFlintHovered() => hoveredItem == FlintSteelId;
    private bool IsLanternHovered() => hoveredItem == LanternId;
    private bool IsFlintDisabled() => !GameState.IsItemCollected(FlintSteelId) && GameState.IsItemCollected(LanternId);
    private bool IsLanternDisabled() => !GameState.IsItemCollected(LanternId) && GameState.IsItemCollected(FlintSteelId);

    private async Task OnFlintSteelClickAsync()
    {
        if (IsFlintDisabled()) return;
        await CollectItem(FlintSteel);
    }

    private async Task OnLanternClickAsync()
    {
        if (IsLanternDisabled()) return;
        await CollectItem(Lantern);
    }

    private void OnFlintSteelEnter() => hoveredItem = FlintSteelId;
    private void OnLanternEnter() => hoveredItem = LanternId;
    private void OnMouseLeave() => hoveredItem = null;

    private async Task CollectItem(GameItem item)
    {
        if (GameState.IsItemCollected(item.Id))
            return;

        // Check if another item is already collected
        if (GameState.Inventory.Count > 0)
            return;

        collectingItem = item.Id;
        StateHasChanged();

        await Task.Delay(600);

        GameState.CollectItem(item);
        collectingItem = null;
        showInventory = true;
    }

    public void Dispose()
    {
        GameState.OnStateChanged -= StateHasChanged;
    }
}
